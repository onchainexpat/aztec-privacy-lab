# Dashboard build-time env. Copy to `.env` for local dev, or set in the Vercel
# project settings for production deploys.

# Public URL of the testnet faucet (see faucet/). When unset, the dashboard's
# testnet "Try variant" panels show the deposit/borrow flows disabled with a
# "faucet not configured" hint.
#
# Example: https://aztec-faucet.your-tailnet.ts.net
# VITE_FAUCET_URL=
