# Admin Schnorr account credentials (the same ones used to deploy the testnet
# contracts via `npm run testnet:setup`). Whoever holds these can mint AZA/AZB
# at will — testnet only, no real funds at risk.
TESTNET_SECRET=0x...
TESTNET_SALT=0x...
TESTNET_SIGNING=0x...

# Optional overrides
# TESTNET_URL=https://rpc.testnet.aztec-labs.com
# PORT=8095
# DATA_DIR=/data
# MINT_AMOUNT=10000
# MINT_COOLDOWN_SECONDS=3600
# CORS_ORIGIN=*
